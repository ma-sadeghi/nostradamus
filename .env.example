# Copy this file to `.env` and fill in real values. The .env file is loaded
# automatically at startup and is git-ignored — never commit secrets.

# Generate one with: uv run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=

# Set to "true" only for local development.
DJANGO_DEBUG=false

# Comma-separated hostnames the site is served from (no scheme).
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Comma-separated origins (with scheme) allowed to submit forms.
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Turn on HTTPS-only cookies, SSL redirect and HSTS. Defaults to on when
# DEBUG is off; set to "false" if you terminate TLS elsewhere or run plain HTTP.
DJANGO_SECURE_SSL=true

# HSTS max-age in seconds (0 disables). Only enable once HTTPS is stable.
DJANGO_HSTS_SECONDS=0

# Optional: override the SQLite database file location.
# DJANGO_DB_PATH=/absolute/path/to/db.sqlite3
